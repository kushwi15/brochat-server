{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017/brochat",
    "DatabaseName": "brochat"
  },
  "Jwt": {
    "Secret": "SUPER_SECRET_KEY_REPLACE_ME_IN_PRODUCTION_NEEDS_TO_BE_AT_LEAST_32_CHARS_LONG",
    "Issuer": "BroChatApi",
    "Audience": "BroChatUsers",
    "ExpiryMinutes": "15",
    "RefreshTokenExpiryDays": "7"
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY_HERE"
  }
}