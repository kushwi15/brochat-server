{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://brochat-client.vercel.app",
    "https://brochat.kushwi.sbs"
  ],
  "MongoDb": {
    "ConnectionString": "FROM_ENV",
    "DatabaseName": "brochat"
  },
  "Jwt": {
    "Secret": "FROM_ENV",
    "Issuer": "BroChatApi",
    "Audience": "BroChatUsers",
    "ExpiryMinutes": "1440",
    "RefreshTokenExpiryDays": "7"
  },
  "Gemini": {
    "ApiKey": "FROM_ENV"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "User": "FROM_ENV",
    "Pass": "FROM_ENV",
    "From": "FROM_ENV"
  }
}